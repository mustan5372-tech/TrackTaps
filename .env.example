# ============================================
# RESEND EMAIL SERVICE CONFIGURATION
# ============================================

# Resend API Key for email delivery
# 1. Go to https://resend.com
# 2. Sign up for free account
# 3. Go to https://resend.com/api-keys
# 4. Create new API key
# 5. Copy the key (format: re_xxxxxxxxxxxxx)
# 6. Paste below
RESEND_API_KEY=re_your_api_key_here

# Email receiver address
# This is where contact form submissions will be sent
CONTACT_RECEIVER_EMAIL=tracktaps@gmail.com

# ============================================
# VERCEL DEPLOYMENT
# ============================================
# Add these environment variables to Vercel:
# 1. Go to https://vercel.com/dashboard
# 2. Select project: track-taps-new
# 3. Settings → Environment Variables
# 4. Add RESEND_API_KEY
# 5. Add CONTACT_RECEIVER_EMAIL
# 6. Redeploy application
